d: #F4C000;\n}\n.bg-number {\n  position: absolute;\n  right: -30px;\n  top: 50%;\n  transform: translateY(-60%);\n  font-family: Anton, sans-serif;\n  font-size: 420px;\n  color: rgba(244,192,0,0.04);\n  line-height: 1;\n  user-select: none;\n}\n.glow {\n  position: absolute;\n  width: 600px;\n  height: 600px;\n  background: radial-gradient(circle, rgba(244,192,0,0.08) 0%, transparent 70%);\n  top: 100px;\n  left: 200px;\n}\n.main {\n  position: relative;\n  z-index: 3;\n  padding: 120px 80px 80px 100px;\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n.step-tag {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n  margin-bottom: 48px;\n}\n.step-num {\n  font-family: Anton, sans-serif;\n  font-size: 80px;\n  color: #F4C000;\n  line-height: 1;\n}\n.step-label {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n.step-word {\n  font-size: 13px;\n  font-weight: 600;\n  letter-spacing: 4px;\n  text-transform: uppercase;\n  color: rgba(255,255,255,0.4);\n}\n.step-name {\n  font-size: 20px;\n  font-weight: 700;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  color: rgba(255,255,255,0.8);\n}\n.headline {\n  font-family: Anton, sans-serif;\n  font-size: 86px;\n  color: #FFFFFF;\n  line-height: 1.0;\n  text-transform: uppercase;\n  margin-bottom: 40px;\n}\n.headline .accent {\n  color: #F4C000;\n}\n.divider {\n  width: 60px;\n  height: 4px;\n  background: #F4C000;\n  margin-bottom: 40px;\n}\n.body-text {\n  font-size: 27px;\n  color: rgba(255,255,255,0.65);\n  line-height: 1.7;\n  max-width: 800px;\n  margin-bottom: 60px;\n}\n.detail-list {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n.detail-item {\n  display: flex;\n  align-items: center;\n  gap: 18px;\n}\n.detail-dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: #F4C000;\n  flex-shrink: 0;\n}\n.detail-text {\n  font-size: 22px;\n  color: rgba(255,255,255,0.5);\n  font-weight: 300;\n}\n.logo {\n  position: absolute;\n  bottom: 56px;\n  right: 72px;\n  width: 64px;\n  opacity: 0.5;\n  z-index: 4;\n}\n</style>\n<div class=\"slide\">\n  <div class=\"yellow-bar\"></div>\n  <div class=\"bg-number\">01</div>\n  <div class=\"glow\"></div>\n  <div class=\"main\">\n    <div class=\"step-tag\">\n      <div class=\"step-num\">01</div>\n      <div class=\"step-label\">\n        <span class=\"step-word\">Paso</span>\n        <span class=\"step-name\">Recepci&oacute;n</span>\n      </div>\n    </div>\n    <div class=\"headline\">Todo<br>empieza<br><span class=\"accent\">aqu&iacute;.</span></div>\n    <div class=\"divider\"></div>\n    <div class=\"body-text\">Cuando traes tu PC al taller,<br>no sos un n&uacute;mero. Sos una persona<br>con un problema que necesita soluci&oacute;n.</div>\n    <div class=\"detail-list\">\n      <div class=\"detail-item\"><div class=\"detail-dot\"></div><span class=\"detail-text\">Registramos tu equipo y tus datos de contacto</span></div>\n      <div class=\"detail-item\"><div class=\"detail-dot\"></div><span class=\"detail-text\">Escuchamos lo que pas&oacute; y qu&eacute; estabas haciendo</span></div>\n      <div class=\"detail-item\"><div class=\"detail-dot\"></div><span class=\"detail-text\">Asignamos un t&eacute;cnico responsable de tu caso</span></div>\n    </div>\n  </div>\n  <img class=\"logo\" src=\"/uploads/64d70ecd-3300-4ef3-b614-7839245e41fb.png\" />\n</div>","previousVersions":[],"order":1,"notes":"Slide 2: Recepción — Paso 01"},{"id":"f4dccca7-b328-488c-86c1-0b818b00a23d","html":"<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\n.slide {\n  width: 1080px;\n  height: 1350px;\n  background: #0D0D0D;\n  display: flex;\n  flex-direction: column;\n  position: relative;\n  overflow: hidden;\n  font-family: Poppins, sans-serif;\n}\n.top-block {\n  background: #F4C000;\n  padding: 80px 80px 70px 80px;\n  position: relative;\n  z-index: 3;\n}\n.step-tag {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  margin-bottom: 20px;\n}\n.s