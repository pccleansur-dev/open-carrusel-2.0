;\n  color: rgba(255,255,255,0.35);\n}\n.step-title {\n  font-size: 22px;\n  font-weight: 700;\n  letter-spacing: 2px;\n  text-transform: uppercase;\n  color: rgba(255,255,255,0.75);\n}\n.headline {\n  font-family: Anton, sans-serif;\n  font-size: 96px;\n  color: #FFFFFF;\n  line-height: 0.95;\n  text-transform: uppercase;\n  margin-bottom: 40px;\n}\n.headline .yellow { color: #F4C000; }\n.fact-box {\n  background: rgba(244,192,0,0.08);\n  border: 1px solid rgba(244,192,0,0.25);\n  border-left: 5px solid #F4C000;\n  border-radius: 0 12px 12px 0;\n  padding: 32px 36px;\n  margin-bottom: 52px;\n}\n.fact-text {\n  font-size: 24px;\n  color: rgba(255,255,255,0.7);\n  line-height: 1.65;\n  font-weight: 300;\n}\n.fact-text strong {\n  color: #F4C000;\n  font-weight: 600;\n}\n.process-row {\n  display: flex;\n  gap: 16px;\n}\n.proc-step {\n  flex: 1;\n  background: rgba(255,255,255,0.03);\n  border: 1px solid rgba(255,255,255,0.07);\n  border-radius: 12px;\n  padding: 24px 20px;\n  text-align: center;\n}\n.proc-icon {\n  font-size: 32px;\n  margin-bottom: 12px;\n}\n.proc-name {\n  font-size: 16px;\n  font-weight: 700;\n  color: rgba(255,255,255,0.7);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n.logo {\n  position: absolute;\n  bottom: 56px;\n  right: 72px;\n  width: 60px;\n  opacity: 0.5;\n  z-index: 4;\n}\n</style>\n<div class=\"slide\">\n  <div class=\"bg-number\">03</div>\n  <div class=\"dust-particles\"></div>\n  <div class=\"glow-center\"></div>\n  <div class=\"main\">\n    <div class=\"step-badge\">\n      <div class=\"step-num\">03</div>\n      <div class=\"step-divider\"></div>\n      <div class=\"step-label\">\n        <span class=\"step-pre\">Paso</span>\n        <span class=\"step-title\">Limpieza</span>\n      </div>\n    </div>\n    <div class=\"headline\">El polvo<br>mata tu <span class=\"yellow\">PC.</span></div>\n    <div class=\"fact-box\">\n      <div class=\"fact-text\">El <strong>80% de las fallas por calor</strong> son causadas por acumul