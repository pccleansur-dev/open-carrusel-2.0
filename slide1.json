{"html":"<style>*{margin:0;padding:0;box-sizing:border-box}.s{width:1080px;height:1350px;background:#0A0A0A;position:relative;overflow:hidden;font-family:'Poppins',sans-serif;padding:90px 80px;display:flex;flex-direction:column;justify-content:space-between}.top{display:flex;justify-content:space-between;align-items:center}.logo{height:46px;filter:brightness(0) invert(1)}.num{font-family:'Anton',sans-serif;color:#F4C000;font-size:22px;letter-spacing:4px}.mid{margin-top:auto}.kicker{font-weight:600;color:#F4C000;font-size:20px;letter-spacing:6px;text-transform:uppercase;margin-bottom:36px}h1{font-family:'Anton',sans-serif;color:#fff;font-size:140px;line-height:0.92;text-transform:uppercase}h1 .y{color:#F4C000}.foot{display:flex;justify-content:space-between;align-items:flex-end;color:#fff;font-size:15px;letter-spacing:3px;text-transform:uppercase}.swipe{color:#F4C000;font-weight:700}</style><div class=\"s\"><div class=\"top\"><img class=\"logo\" src=\"/uploads/64d70ecd-3300-4ef3-b614-7839245e41fb.png\"><div class=\"num\">01 / 06</div></div><div class=\"mid\"><div class=\"kicker\">— Guía rápida</div><h1>Lo que <span class=\"y\">NO</span> deberías hacer con tu notebook</h1></div><div class=\"foot\"><span>Pc Clean</span><span class=\"swipe\">Deslizá →</span></div></div>"}
