{"html":"<style>*{margin:0;padding:0;box-sizing:border-box}.slide{width:1080px;height:1350px;background:#0D0D0D;display:flex;flex-direction:column;position:relative;overflow:hidden;font-family:Poppins,sans-serif;color:#fff}.glow-top{position:absolute;width:780px;height:780px;background:radial-gradient(circle,rgba(244,192,0,0.16) 0%,transparent 65%);top:-220px;right:-180px}.glow-bottom{position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(46,31,163,0.28) 0%,transparent 70%);bottom:-180px;left:-140px}.grid-lines{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:80px 80px}.top{position:relative;z-index:3;display:flex;justify-content:space-between;align-items:center;padding:60px 80px 0}.logo{height:42px;filter:brightness(0) invert(1)}.num{font-family:Anton,sans-serif;font-size:22px;letter-spacing:4px;color:#F4C000}.main{position:relative;z-index:3;padding:80px 80px 60px;flex:1;display:flex;flex-direction:column;justify-content:center}.kicker{display:inline-block;border:2px solid rgba(244,192,0,0.5);color:#F4C000;font-size:16px;font-weight:600;letter-spacing:5px;text-transform:uppercase;padding:10px 26px;margin-bottom:48px;align-self:flex-start}.headline{font-family:Anton,sans-serif;font-size:138px;line-height:0.92;text-transform:uppercase;margin-bottom:36px}.headline .u{color:#F4C000;border-bottom:8px solid #F4C000;padding-bottom:6px;display:inline-block;line-height:1}.divider{width:60px;height:4px;background:#F4C000;margin-bottom:36px}.body-text{font-size:26px;color:rgba(255,255,255,0.7);line-height:1.6;max-width:880px;margin-bottom:56px;font-weight:400}.body-text strong{color:#fff;font-weight:600}.cta-row{display:flex;align-items:center;gap:28px}.cta{background:#F4C000;color:#0A0A0A;padding:30px 56px;font-family:Anton,sans-serif;font-size:36px;letter-spacing:3px;text-transform:uppercase;box-shadow:0 10px 40px rgba(244,192,0,0.25)}.cta-sub{font-size:18px;color:rgba(255,255,255,0.55);letter-spacing:2px;text-transform:uppercase;font-weight:500;max-width:200px;line-height:1.4}.foot{position:relative;z-index:3;padding:0 80px 56px;font-size:15px;letter-spacing:3px;text-transform:uppercase;font-weight:600;color:rgba(255,255,255,0.4)}.foot .handle{color:#F4C000}</style><div class=\"slide\"><div class=\"glow-top\"></div><div class=\"glow-bottom\"></div><div class=\"grid-lines\"></div><div class=\"top\"><img class=\"logo\" src=\"/uploads/64d70ecd-3300-4ef3-b614-7839245e41fb.png\"><div class=\"num\">06 / 06</div></div><div class=\"main\"><div class=\"kicker\">— Mantenimiento</div><div class=\"headline\">Cuidala<br>antes de que <span class=\"u\">falle</span></div><div class=\"divider\"></div><div class=\"body-text\">En <strong>Pc Clean</strong> hacemos mantenimiento preventivo: limpieza interna, cambio de pasta térmica y diagnóstico completo.</div><div class=\"cta-row\"><div class=\"cta\">Escribinos →</div><div class=\"cta-sub\">Turno por DM o WhatsApp</div></div></div><div class=\"foot\">Pc Clean · <span class=\"handle\">@pcclean</span></div></div>","notes":"Slide 6 - CTA final (dark)"}
