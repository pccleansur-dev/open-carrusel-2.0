{"html":"<style>*{margin:0;padding:0;box-sizing:border-box}.slide{width:1080px;height:1350px;background:#0D0D0D;display:flex;flex-direction:column;justify-content:center;align-items:center;position:relative;overflow:hidden;font-family:Poppins,sans-serif}.glow-top{position:absolute;width:780px;height:780px;background:radial-gradient(circle,rgba(244,192,0,0.18) 0%,transparent 65%);top:-220px;right:-160px}.glow-bottom{position:absolute;width:560px;height:560px;background:radial-gradient(circle,rgba(46,31,163,0.18) 0%,transparent 70%);bottom:-180px;left:-120px}.grid-lines{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:80px 80px}.content{position:relative;z-index:3;text-align:center;padding:0 80px;margin-top:-40px}.badge{display:inline-block;border:2px solid rgba(244,192,0,0.5);color:#F4C000;font-size:18px;font-weight:600;letter-spacing:4px;text-transform:uppercase;padding:10px 28px;margin-bottom:48px}.headline{font-family:Anton,sans-serif;font-size:108px;color:#FFFFFF;line-height:1.0;text-transform:uppercase;margin-bottom:32px;letter-spacing:-1px}.headline .yellow{color:#F4C000;display:block}.divider{width:60px;height:4px;background:#F4C000;margin:0 auto 36px}.sub{font-size:26px;color:rgba(255,255,255,0.6);font-weight:300;line-height:1.7;max-width:760px;margin:0 auto 60px}.cta-btn{display:inline-block;background:#F4C000;color:#0D0D0D;font-family:Anton,sans-serif;font-size:36px;letter-spacing:3px;text-transform:uppercase;padding:24px 56px;border-radius:6px;box-shadow:0 0 50px rgba(244,192,0,0.4);margin-bottom:32px}.contact{font-size:20px;color:rgba(255,255,255,0.6);letter-spacing:2px}.contact strong{color:#F4C000;font-weight:600}.logo{position:absolute;bottom:56px;right:72px;width:72px;opacity:0.6;z-index:4}.step-indicator{position:absolute;bottom:60px;left:80px;display:flex;gap:8px;z-index:4}.dot{width:28px;height:4px;background:#F4C000;border-radius:2px}.dot-inactive{width:12px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px}</style><div class=\"slide\"><div class=\"glow-top\"></div><div class=\"glow-bottom\"></div><div class=\"grid-lines\"></div><div class=\"content\"><div class=\"badge\">PC Clean &middot; Soluci&oacute;n</div><div class=\"headline\">Bajale<br>la fiebre<br><span class=\"yellow\">a tu PC.</span></div><div class=\"divider\"></div><div class=\"sub\">Limpieza interna profesional + pasta t&eacute;rmica nueva.<br>Tu PC vuelve a respirar, rinde m&aacute;s y dura m&aacute;s.</div><div class=\"cta-btn\">Resev&aacute; tu turno</div><div class=\"contact\">Escribinos por <strong>WhatsApp</strong> &middot; @pcclean</div></div><img class=\"logo\" src=\"/uploads/64d70ecd-3300-4ef3-b614-7839245e41fb.png\" /><div class=\"step-indicator\"><div class=\"dot-inactive\"></div><div class=\"dot-inactive\"></div><div class=\"dot-inactive\"></div><div class=\"dot-inactive\"></div><div class=\"dot-inactive\"></div><div class=\"dot\"></div></div></div>","notes":"Slide 6: CTA Limpieza — Reservá turno, WhatsApp"}
